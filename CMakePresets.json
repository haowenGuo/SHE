{
  "version": 2,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default Configure",
      "generator": "Visual Studio 16 2019",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/default",
      "cacheVariables": {
        "SHE_BUILD_SANDBOX": "ON",
        "SHE_ENABLE_TESTS": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release Configure",
      "inherits": "default",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "SHE_BUILD_SANDBOX": "ON",
        "SHE_ENABLE_TESTS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-default",
      "configurePreset": "default",
      "configuration": "Debug"
    },
    {
      "name": "build-release",
      "configurePreset": "release",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "test-default",
      "configurePreset": "default",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
